{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "intt/megamenu",
  "title": "Mega Menú",
  "description": "Barra de navegación principal con panel de megamenú.",
  "category": "theme",
  "textdomain": "intt-theme",
  "render": "file:./render.php",
  "editorScript": "file:./index.js",
  "attributes": {
    "navRef": {
      "type": "number",
      "default": 0
    }
  },
  "supports": {
    "html": false,
    "multiple": false,
    "reusable": false
  }
}
